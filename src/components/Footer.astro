---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="footer-hearts">💝 Made with love 💝</div>
    <div class="footer-text">
      <span class="year">{today.getFullYear()}</span>
      <span class="name">亚冬的小窝</span>
    </div>
    <div class="footer-decoration">
      🌸 🌿 ✨ 🌸
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 2rem;
    text-align: center;
    background: linear-gradient(135deg, #fff5f5 0%, #fff0f3 100%);
    border-top: 1px solid rgba(255, 154, 158, 0.2);
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-hearts {
    color: #ff9a9e;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .footer-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .year {
    color: #ff9a9e;
    font-weight: 600;
  }
  .name {
    color: var(--text-primary);
    font-weight: 500;
  }
  .footer-decoration {
    color: #ff9a9e;
    font-size: 1rem;
    letter-spacing: 0.5rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }
</style>
