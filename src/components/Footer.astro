---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <span class="footer-text">© {today.getFullYear()} 孙亚冬的内省地</span>
  </div>
</footer>

<style>
  footer {
    padding: 2rem;
    text-align: center;
    background: #ffffff;
    border-top: 1px solid #e5e5e5;
  }
  .footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .footer-text {
    color: #666666;
    font-size: 0.85rem;
    font-weight: 400;
  }
</style>
