---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="孙亚冬的内省地">
  <Header />
  <main>
    <div class="hero">
      <h1 class="slogan">
        活得简单点、幸福点、自由点
      </h1>
      <p class="subtitle">
        和优秀的人，做伟大的事
      </p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero {
    text-align: center;
  }

  .slogan {
    font-size: 1.75rem;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 1rem;
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .subtitle {
    font-size: 1.1rem;
    font-weight: 400;
    color: #999999;
    margin: 0;
    letter-spacing: 0.15em;
  }

  @media (max-width: 600px) {
    .slogan {
      font-size: 1.4rem;
      letter-spacing: 0.05em;
    }
    .subtitle {
      font-size: 1rem;
      letter-spacing: 0.08em;
    }
  }
</style>
