---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const modules = [
  {
    title: '健康幸福',
    href: '/wellness',
    desc: '身体是灵魂的容器',
    icon: '🌱'
  },
  {
    title: '事业有成',
    href: '/career',
    desc: '在代码世界里探索',
    icon: '💻'
  },
  {
    title: '财富自由',
    href: '/wealth',
    desc: '金钱是工具，自由是目的',
    icon: '💎'
  },
  {
    title: '随念随想',
    href: '/thoughts',
    desc: '捕捉稍纵即逝的思绪',
    icon: '💭'
  },
];
---

<Layout title="孙亚冬的数字花园">
  <Header />
  <main>
    <section class="hero">
      <h1>
        <span class="text-gradient">数字花园</span>
      </h1>
      <p class="intro">
        人生是一场修行，文字是思考的轨迹。<br/>
        在这里记录成长，分享感悟。
      </p>
    </section>

    <section class="modules">
      {modules.map(module => (
        <a href={module.href} class="module-card">
          <span class="module-icon">{module.icon}</span>
          <h3>{module.title}</h3>
          <p>{module.desc}</p>
        </a>
      ))}
    </section>

    <section class="cta">
      <a href="/about" class="button">关于 @孙亚冬</a>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }
  h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }
  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
  .intro {
    color: var(--text-secondary);
    font-size: 1.15rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 2rem 0;
  }
  .module-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
    text-align: center;
  }
  .module-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    border-color: rgb(var(--accent));
  }
  .module-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    display: block;
  }
  .module-card h3 {
    color: var(--text-primary);
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
  }
  .module-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin: 0;
  }
  .cta {
    text-align: center;
    margin-top: 2rem;
  }
  .button {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    background: rgb(var(--accent));
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.3);
  }
  .button:hover {
    background: rgb(var(--accent-dark));
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
  }
  @media (max-width: 600px) {
    .modules {
      grid-template-columns: 1fr;
    }
  }
</style>
