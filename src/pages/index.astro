---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="欢迎来到我的博客">
  <Header />
  <main>
    <section class="hero">
      <h1>
        <span class="text-gradient">欢迎来到</span>
        <br />
        我的个人博客
      </h1>
      <p class="intro">
        这里记录我的技术学习、生活感悟和各种有趣的发现。
      </p>
    </section>
    <section class="cta">
      <a href="/blog" class="button">浏览文章</a>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }
  .hero {
    text-align: center;
    padding: 4rem 0;
  }
  h1 {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.2;
    color: white;
    margin: 0 0 1rem 0;
  }
  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
  .intro {
    color: rgb(200, 200, 200);
    font-size: 1.25rem;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .cta {
    text-align: center;
    margin-top: 2rem;
  }
  .button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: rgb(var(--accent));
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    transition: background 0.2s;
  }
  .button:hover {
    background: rgb(var(--accent-dark));
  }
</style>
