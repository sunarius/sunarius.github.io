---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const posts = [
  {
    title: '我的理财心得',
    description: '从月光族到开始理财，分享我的经验和教训。',
    date: new Date('2024-02-10'),
    slug: 'my-finance-tips'
  },
  {
    title: '指数基金入门',
    description: '适合普通人的投资方式，从零开始学习指数基金。',
    date: new Date('2024-02-15'),
    slug: 'index-fund-guide'
  }
];
---

<Layout title="💎 财富自由">
  <Header />
  <main>
    <div class="section-header">
      <span class="section-icon">💎</span>
      <h1>财富自由</h1>
      <p class="section-desc">金钱是工具，自由才是目的</p>
    </div>

    <div class="posts-grid">
      {posts.map((post, index) => (
        <article class="post-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="card-header">
            <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
            <span class="date">{post.date.toLocaleDateString('zh-CN')}</span>
          </div>
          <p class="card-desc">{post.description}</p>
          <div class="card-footer">
            <span class="read-more">阅读更多 →</span>
          </div>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }

  .section-header {
    text-align: center;
    padding: 2rem 0;
  }

  .section-icon {
    font-size: 4rem;
    display: inline-block;
    animation: sparkle 2s ease-in-out infinite;
  }

  @keyframes sparkle {
    0%, 100% { transform: scale(1); filter: brightness(1); }
    50% { transform: scale(1.1); filter: brightness(1.2); }
  }

  h1 {
    color: #faad14;
    font-size: 2rem;
    margin: 1rem 0 0.5rem;
    font-weight: 700;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .post-card {
    background: white;
    border: 1px solid rgba(250, 173, 20, 0.15);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s;
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    to { opacity: 1; transform: translateY(0); }
    from { opacity: 0; transform: translateY(20px); }
  }

  .post-card:hover {
    border-color: rgba(250, 173, 20, 0.3);
    box-shadow: 0 4px 20px rgba(250, 173, 20, 0.1);
    transform: translateY(-3px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.2rem;
    flex: 1;
  }

  .card-header h3 a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
  }

  .card-header h3 a:hover {
    color: #faad14;
  }

  .date {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .card-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(250, 173, 20, 0.1);
  }

  .read-more {
    color: #faad14;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
  }

  .read-more:hover {
    color: #d48806;
  }
</style>
