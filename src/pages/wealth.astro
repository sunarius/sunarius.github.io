---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  { title: '📈 投资理财', desc: '指数基金、股票分析、资产配置', href: '/wealth/investment' },
  { title: '📊 理财规划', desc: '资产负债表、应急资金、退休规划', href: '/wealth/planning' },
  { title: '💳 消费管理', desc: '记账方法、预算制定、理性消费', href: '/wealth/spending' },
  { title: '💰 开源增收', desc: '副业探索、技能变现、被动收入', href: '/wealth/income' },
];
---

<Layout title="💎 财富自由">
  <Header />
  <main>
    <div class="page-header">
      <span class="icon">💎</span>
      <h1>财富自由</h1>
      <p class="lead">金钱是工具，自由才是目的</p>
    </div>

    <div class="sections-grid">
      {sections.map(section => (
        <a href={section.href} class="section-card">
          <h2>{section.title}</h2>
          <p>{section.desc}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 140px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: #666666;
    margin: 0;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .section-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .section-card:hover {
    border-color: #1a1a1a;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .section-card h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .section-card p {
    font-size: 0.9rem;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    main {
      padding: 2rem 1rem;
    }
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
