---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  { title: '🏃 运动健身', desc: '跑步训练、居家健身、瑜伽入门', href: '/wellness/fitness' },
  { title: '🥗 饮食营养', desc: '均衡膳食、健康食谱、间歇性断食', href: '/wellness/nutrition' },
  { title: '🧘 心理健康', desc: '冥想练习、压力管理、睡眠优化', href: '/wellness/mental' },
  { title: '✅ 习惯养成', desc: '晨间惯例、微习惯、习惯追踪', href: '/wellness/habits' },
];
---

<Layout title="🌿 健康幸福">
  <Header />
  <main>
    <div class="page-header">
      <span class="icon">🌿</span>
      <h1>健康幸福</h1>
      <p class="lead">身体是灵魂的容器，幸福是生命最本真的追求</p>
    </div>

    <div class="sections-grid">
      {sections.map(section => (
        <a href={section.href} class="section-card">
          <h2>{section.title}</h2>
          <p>{section.desc}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 140px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: #666666;
    margin: 0;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .section-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .section-card:hover {
    border-color: #1a1a1a;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .section-card h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .section-card p {
    font-size: 0.9rem;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    main {
      padding: 2rem 1rem;
    }
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
