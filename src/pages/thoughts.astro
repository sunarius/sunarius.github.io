---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  { title: '📚 读书笔记', desc: '年度书单、技术书籍、思维模型', href: '/thoughts/reading' },
  { title: '🌱 生活感悟', desc: '极简主义、时间管理、人际关系', href: '/thoughts/life' },
  { title: '💡 技术思考', desc: '架构设计、代码质量、技术趋势', href: '/thoughts/tech' },
  { title: '✍️ 随笔杂谈', desc: '周末随笔、旅行见闻、电影影评', href: '/thoughts/essays' },
];
---

<Layout title="💭 随念随想">
  <Header />
  <main>
    <div class="page-header">
      <span class="icon">💭</span>
      <h1>随念随想</h1>
      <p class="lead">思绪如风，念头如云</p>
    </div>

    <div class="sections-grid">
      {sections.map(section => (
        <a href={section.href} class="section-card">
          <h2>{section.title}</h2>
          <p>{section.desc}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 140px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: #666666;
    margin: 0;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .section-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .section-card:hover {
    border-color: #1a1a1a;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .section-card h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .section-card p {
    font-size: 0.9rem;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    main {
      padding: 2rem 1rem;
    }
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
