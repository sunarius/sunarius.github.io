---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const posts = [
  {
    title: '雨天的午后',
    description: '窗外的雨声，手中的咖啡，此刻的宁静。',
    date: new Date('2024-02-20'),
    slug: 'rainy-afternoon'
  },
  {
    title: '关于时间管理的思考',
    description: '时间是最公平的资源，如何使用决定了人生的质量。',
    date: new Date('2024-02-22'),
    slug: 'time-management-thoughts'
  }
];
---

<Layout title="💭 随念随想">
  <Header />
  <main>
    <div class="section-header">
      <span class="section-icon">💭</span>
      <h1>随念随想</h1>
      <p class="section-desc">思绪如风，念头如云</p>
    </div>

    <div class="posts-grid">
      {posts.map((post, index) => (
        <article class="post-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="card-header">
            <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
            <span class="date">{post.date.toLocaleDateString('zh-CN')}</span>
          </div>
          <p class="card-desc">{post.description}</p>
          <div class="card-footer">
            <span class="read-more">阅读更多 →</span>
          </div>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }

  .section-header {
    text-align: center;
    padding: 2rem 0;
  }

  .section-icon {
    font-size: 4rem;
    display: inline-block;
    animation: drift 4s ease-in-out infinite;
  }

  @keyframes drift {
    0%, 100% { transform: translateX(0) translateY(0); }
    25% { transform: translateX(5px) translateY(-5px); }
    50% { transform: translateX(0) translateY(-10px); }
    75% { transform: translateX(-5px) translateY(-5px); }
  }

  h1 {
    color: #722ed1;
    font-size: 2rem;
    margin: 1rem 0 0.5rem;
    font-weight: 700;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .post-card {
    background: white;
    border: 1px solid rgba(114, 46, 209, 0.15);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s;
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    to { opacity: 1; transform: translateY(0); }
    from { opacity: 0; transform: translateY(20px); }
  }

  .post-card:hover {
    border-color: rgba(114, 46, 209, 0.3);
    box-shadow: 0 4px 20px rgba(114, 46, 209, 0.1);
    transform: translateY(-3px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.2rem;
    flex: 1;
  }

  .card-header h3 a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
  }

  .card-header h3 a:hover {
    color: #722ed1;
  }

  .date {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .card-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(114, 46, 209, 0.1);
  }

  .read-more {
    color: #722ed1;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
  }

  .read-more:hover {
    color: #531dab;
  }
</style>
