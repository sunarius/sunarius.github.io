---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const modules = [
  { name: '健康幸福', icon: '🌿', color: '#52c41a', href: '/wellness' },
  { name: '事业有成', icon: '💼', color: '#1890ff', href: '/career' },
  { name: '财富自由', icon: '💎', color: '#faad14', href: '/wealth' },
  { name: '随念随想', icon: '💭', color: '#722ed1', href: '/thoughts' },
];
---

<Layout title="👋 孙亚冬">
  <Header />
  <main>
    <div class="about-card">
      <div class="profile-section">
        <div class="avatar">
          <span class="avatar-emoji">👋</span>
        </div>
        <h1>你好，我是孙亚冬</h1>
        <p class="tagline">代码工匠 · 终身学习者 · 生活探索者</p>
      </div>

      <div class="intro-section">
        <p>
          欢迎来到我的小窝！这里是我记录生活、分享成长的地方 💝
        </p>
        <p>
          人生是一场修行，而文字是思考的轨迹。
          愿在这里与你分享成长，共同进步 ✨
        </p>
      </div>

      <div class="modules-section">
        <h2>这里有什么</h2>
        <div class="modules-grid">
          {modules.map(module => (
            <a href={module.href} class="module-item" style={`--module-color: ${module.color}`}>
              <span class="module-icon">{module.icon}</span>
              <span class="module-name">{module.name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="contact-section">
        <h2>找到我</h2>
        <div class="contact-list">
          <a href="https://github.com/yadongSun" target="_blank" class="contact-item">
            <span class="contact-icon">🐙</span>
            <span class="contact-text">GitHub @yadongSun</span>
          </a>
          <a href="https://sunarius.github.io" class="contact-item">
            <span class="contact-icon">🌐</span>
            <span class="contact-text">sunarius.github.io</span>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }

  .about-card {
    background: white;
    border: 1px solid rgba(255, 154, 158, 0.2);
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: 0 4px 20px rgba(255, 154, 158, 0.1);
  }

  .profile-section {
    text-align: center;
    margin-bottom: 2rem;
  }

  .avatar {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    box-shadow: 0 4px 20px rgba(255, 154, 158, 0.3);
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .avatar-emoji {
    font-size: 3rem;
  }

  h1 {
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    font-size: 1.8rem;
    font-weight: 700;
  }

  .tagline {
    color: var(--text-secondary);
    margin: 0;
    font-size: 1rem;
  }

  .intro-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: linear-gradient(135deg, #fff5f5 0%, #fff0f3 100%);
    border-radius: 16px;
  }

  .intro-section p {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .intro-section p:last-child {
    margin-bottom: 0;
  }

  .modules-section, .contact-section {
    margin-top: 2rem;
  }

  h2 {
    color: var(--text-primary);
    font-size: 1.2rem;
    margin: 0 0 1rem;
    font-weight: 600;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .module-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .module-item:hover {
    border-color: var(--module-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .module-icon {
    font-size: 1.5rem;
  }

  .module-name {
    color: var(--text-primary);
    font-weight: 500;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .contact-item:hover {
    border-color: #ff9a9e;
    transform: translateX(5px);
  }

  .contact-icon {
    font-size: 1.25rem;
  }

  .contact-text {
    color: var(--text-secondary);
  }

  .contact-item:hover .contact-text {
    color: #ff9a9e;
  }

  @media (max-width: 600px) {
    .about-card {
      padding: 1.5rem;
    }
    .modules-grid {
      grid-template-columns: 1fr;
    }
    h1 {
      font-size: 1.5rem;
    }
  }
</style>
