---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  { title: '🛡️ 安全运营', desc: 'SOC建设、威胁情报、应急响应', href: '/career/soc' },
  { title: '🔒 办公安全', desc: '零信任架构、终端安全、邮件安全', href: '/career/office' },
  { title: '🔐 数据安全', desc: '数据分类、隐私计算、数据脱敏', href: '/career/data' },
  { title: '📋 安全治理', desc: '合规框架、安全审计、风险评估', href: '/career/governance' },
  { title: '🤖 AI安全', desc: '模型安全、AIGC安全、AI Agent安全', href: '/career/ai-security' },
];
---

<Layout title="💼 事业有成">
  <Header />
  <main>
    <div class="page-header">
      <span class="icon">💼</span>
      <h1>事业有成</h1>
      <p class="lead">在代码的世界里探索，在事业的征途中前行</p>
    </div>

    <div class="sections-grid">
      {sections.map(section => (
        <a href={section.href} class="section-card">
          <h2>{section.title}</h2>
          <p>{section.desc}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 140px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .lead {
    font-size: 1.1rem;
    color: #666666;
    margin: 0;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .section-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .section-card:hover {
    border-color: #1a1a1a;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .section-card h2 {
    font-size: 1.1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
  }

  .section-card p {
    font-size: 0.9rem;
    color: #666666;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    main {
      padding: 2rem 1rem;
    }
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
