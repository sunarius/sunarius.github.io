---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const posts = [
  {
    title: '技术成长路线图',
    description: '从初级到高级，我的技术成长心得与规划。',
    date: new Date('2024-02-01'),
    slug: 'tech-growth-roadmap'
  },
  {
    title: 'Astro 博客搭建心得',
    description: '分享使用 Astro 搭建静态博客的经验和踩过的坑。',
    date: new Date('2024-01-20'),
    slug: 'astro-blog-tips'
  }
];
---

<Layout title="💼 事业有成">
  <Header />
  <main>
    <div class="section-header">
      <span class="section-icon">💼</span>
      <h1>事业有成</h1>
      <p class="section-desc">在代码的世界里探索，在事业的征途中前行</p>
    </div>

    <div class="posts-grid">
      {posts.map((post, index) => (
        <article class="post-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="card-header">
            <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
            <span class="date">{post.date.toLocaleDateString('zh-CN')}</span>
          </div>
          <p class="card-desc">{post.description}</p>
          <div class="card-footer">
            <span class="read-more">阅读更多 →</span>
          </div>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    min-height: calc(100vh - 200px);
  }

  .section-header {
    text-align: center;
    padding: 2rem 0;
  }

  .section-icon {
    font-size: 4rem;
    display: inline-block;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-5deg); }
  }

  h1 {
    color: #1890ff;
    font-size: 2rem;
    margin: 1rem 0 0.5rem;
    font-weight: 700;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .post-card {
    background: white;
    border: 1px solid rgba(24, 144, 255, 0.15);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s;
    animation: fadeIn 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    to { opacity: 1; transform: translateY(0); }
    from { opacity: 0; transform: translateY(20px); }
  }

  .post-card:hover {
    border-color: rgba(24, 144, 255, 0.3);
    box-shadow: 0 4px 20px rgba(24, 144, 255, 0.1);
    transform: translateY(-3px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.2rem;
    flex: 1;
  }

  .card-header h3 a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
  }

  .card-header h3 a:hover {
    color: #1890ff;
  }

  .date {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .card-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .card-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(24, 144, 255, 0.1);
  }

  .read-more {
    color: #1890ff;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
  }

  .read-more:hover {
    color: #096dd9;
  }
</style>
