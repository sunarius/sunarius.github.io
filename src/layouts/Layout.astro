---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "我的个人博客" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --accent: 0, 255, 255;
    --accent-light: 255, 0, 255;
    --accent-dark: 0, 200, 200;
    --accent-gradient: linear-gradient(
      45deg,
      #00ffff,
      #ff00ff 50%,
      #00ff88 100%
    );
    --bg-primary: #0a0a12;
    --bg-secondary: #12121f;
    --bg-header: #0d0d18;
    --text-primary: #e0e0ff;
    --text-secondary: #a0a0c0;
    --text-muted: #606080;
    --border-color: #00ffff;
    --neon-cyan: #00ffff;
    --neon-pink: #ff00ff;
    --neon-green: #00ff88;
    --neon-purple: #8b5cf6;
  }
  html {
    font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    overflow-x: hidden;
  }
  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 20% 80%, rgba(0, 255, 255, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255, 0, 255, 0.03) 0%, transparent 50%),
      var(--bg-primary);
  }
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 255, 255, 0.03) 2px,
        rgba(0, 255, 255, 0.03) 4px
      );
    pointer-events: none;
    z-index: 1000;
  }
  ::selection {
    background: rgba(0, 255, 255, 0.3);
    color: #fff;
  }
  code {
    font-family:
      'Fira Code',
      Menlo,
      Monaco,
      'Courier New',
      monospace;
    background: rgba(0, 255, 255, 0.1);
    border: 1px solid rgba(0, 255, 255, 0.3);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    color: #00ffff;
  }
  pre code {
    padding: 0;
    background: transparent;
    border: none;
  }
</style>
