---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  module: string;
  moduleHref: string;
  sections: Array<{ id: string; title: string; href: string }>;
  currentSection: string;
  subSections?: Array<{ id: string; title: string; href: string }>;
  currentSubSection?: string;
}

const { title, module, moduleHref, sections, currentSection, subSections = [], currentSubSection = '' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | {module}</title>
    <style is:global>
      :root {
        --text-primary: #1a1a1a;
        --text-secondary: #666666;
        --text-muted: #999999;
        --border-color: #e5e5e5;
        --bg-primary: #ffffff;
        --bg-secondary: #f5f5f5;
      }
      html {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
      }
      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="doc-container">
      <aside class="sidebar">
        <div class="sidebar-header">
          <a href={moduleHref} class="module-link">{module}</a>
        </div>
        <nav class="nav-menu">
          {sections.map(section => {
            const isActive = section.id === currentSection;
            const hasSubSections = isActive && subSections.length > 0;
            return (
              <div class={`nav-item ${hasSubSections ? 'has-children' : ''}`}>
                <a
                  href={section.href}
                  class={`nav-link ${isActive ? 'active' : ''}`}
                >
                  {section.title}
                </a>
                {hasSubSections && (
                  <div class="sub-nav">
                    {subSections.map(sub => (
                      <a
                        href={sub.href}
                        class={`sub-nav-link ${sub.id === currentSubSection ? 'active' : ''}`}
                      >
                        {sub.title}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            );
          })}
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  .doc-container {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 120px);
  }

  .sidebar {
    flex: 0 0 260px;
    border-right: 1px solid var(--border-color);
    padding: 2rem 1.25rem;
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .sidebar-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .module-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .module-link:hover {
    color: var(--text-secondary);
  }

  .nav-menu {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-item {
    display: flex;
    flex-direction: column;
  }

  .nav-item.has-children {
    gap: 0.25rem;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    transition: all 0.15s;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
  }

  .nav-link.active {
    color: var(--text-primary);
    background: var(--bg-secondary);
    font-weight: 500;
  }

  .sub-nav {
    display: flex;
    flex-direction: column;
    margin-left: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--border-color);
    gap: 0.15rem;
  }

  .sub-nav-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    transition: all 0.15s;
  }

  .sub-nav-link:hover {
    color: var(--text-secondary);
    background: var(--bg-secondary);
  }

  .sub-nav-link.active {
    color: var(--text-primary);
    background: var(--bg-secondary);
    font-weight: 500;
  }

  .content {
    flex: 1;
    padding: 2rem 3rem;
    max-width: 700px;
  }

  .content :global(h1) {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }

  .content :global(.lead) {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .content :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 1.5rem 0 0.75rem;
  }

  .content :global(p) {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0 0 1rem;
  }

  .content :global(ul) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .sidebar {
      display: none;
    }
    .content {
      padding: 2rem 1.5rem;
      max-width: 100%;
    }
  }
</style>
